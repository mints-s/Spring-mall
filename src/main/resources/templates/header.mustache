<!doctype html>
<html lang="ko">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <title>ShopMall</title>
    <style>
        :root {
            --sky-50:  #f0f9ff;
            --sky-100: #e0f2fe;
            --sky-200: #bae6fd;
            --sky-400: #38bdf8;
            --sky-500: #0ea5e9;
            --sky-600: #0284c7;
            --sky-700: #0369a1;
            --sky-900: #0c4a6e;
            --text-dark: #1e293b;
            --text-muted: #64748b;
            --radius-card: 18px;
        }

        * { box-sizing: border-box; }
        body { background: #f8faff; color: var(--text-dark); font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }

        /* ── Navbar ── */
        .nav-shop {
            background: linear-gradient(135deg, var(--sky-900) 0%, var(--sky-700) 50%, var(--sky-500) 100%);
            box-shadow: 0 4px 24px rgba(3,105,161,.35);
            padding: 0 0;
        }
        .nav-shop .navbar-brand {
            font-size: 1.4rem; font-weight: 800; color: #fff !important;
            letter-spacing: -0.5px;
        }
        .nav-shop .navbar-brand span { color: var(--sky-200); }
        .nav-shop .nav-link { color: rgba(255,255,255,.8) !important; font-weight: 500; font-size: .9rem; padding: .6rem .9rem !important; border-radius: 8px; transition: all .2s; }
        .nav-shop .nav-link:hover { color: #fff !important; background: rgba(255,255,255,.12); }
        .nav-shop .nav-link.active-cat { color: #fff !important; background: rgba(255,255,255,.18); }

        /* Search */
        .nav-search .form-control {
            border: none; border-radius: 10px 0 0 10px;
            background: rgba(255,255,255,.15); color: #fff;
            font-size: .875rem; min-width: 220px;
        }
        .nav-search .form-control::placeholder { color: rgba(255,255,255,.6); }
        .nav-search .form-control:focus { background: rgba(255,255,255,.25); box-shadow: none; color: #fff; }
        .nav-search .btn { border-radius: 0 10px 10px 0; background: rgba(255,255,255,.2); border: none; color: #fff; }
        .nav-search .btn:hover { background: rgba(255,255,255,.3); }

        /* User badges */
        .user-pill { background: rgba(255,255,255,.18); border-radius: 24px; padding: 4px 14px; color: rgba(255,255,255,.9); font-size: .8rem; display: flex; align-items: center; gap: 6px; }
        .admin-pill { background: rgba(251,191,36,.25); border: 1px solid rgba(251,191,36,.4); border-radius: 24px; padding: 4px 10px; color: #fef3c7; font-size: .78rem; }
        .nav-btn-outline { border: 1.5px solid rgba(255,255,255,.5); border-radius: 8px; padding: 5px 14px; color: rgba(255,255,255,.9) !important; font-size: .82rem; transition: all .2s; }
        .nav-btn-outline:hover { background: rgba(255,255,255,.15); color: #fff !important; }
        .nav-btn-solid { background: rgba(255,255,255,.9); border-radius: 8px; padding: 5px 14px; color: var(--sky-700) !important; font-size: .82rem; font-weight: 600; transition: all .2s; }
        .nav-btn-solid:hover { background: #fff; }

        /* ── Cards ── */
        .shop-card {
            background: #fff; border: 1px solid var(--sky-100);
            border-radius: var(--radius-card); transition: transform .25s, box-shadow .25s;
        }
        .shop-card:hover { transform: translateY(-5px); box-shadow: 0 16px 48px rgba(14,165,233,.18); border-color: var(--sky-200); }

        .product-img-wrap {
            aspect-ratio: 1/1; background: var(--sky-50);
            border-radius: var(--radius-card) var(--radius-card) 0 0;
            display: flex; align-items: center; justify-content: center; overflow: hidden;
        }
        .product-img-wrap img { width: 100%; height: 100%; object-fit: cover; }
        .product-img-placeholder { color: var(--sky-200); font-size: 3rem; }

        /* Badge */
        .cat-badge { background: var(--sky-100); color: var(--sky-700); border-radius: 20px; padding: 3px 10px; font-size: .72rem; font-weight: 600; display: inline-block; }
        .cat-badge-lg { padding: 5px 14px; font-size: .8rem; }

        /* Price */
        .price-tag { color: var(--sky-700); font-weight: 800; }

        /* Buttons */
        .btn-sky { background: var(--sky-500); border: none; color: #fff; border-radius: 10px; font-weight: 600; transition: all .2s; }
        .btn-sky:hover { background: var(--sky-600); color: #fff; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(14,165,233,.35); }
        .btn-sky:active { transform: translateY(0); }
        .btn-sky-outline { border: 1.5px solid var(--sky-500); color: var(--sky-600); border-radius: 10px; font-weight: 600; background: transparent; transition: all .2s; }
        .btn-sky-outline:hover { background: var(--sky-50); }

        /* Inputs */
        .input-sky:focus { border-color: var(--sky-400); box-shadow: 0 0 0 3px rgba(14,165,233,.15); }

        /* Review / Article */
        .review-card { background: #fff; border: 1px solid var(--sky-100); border-radius: 14px; padding: 20px 24px; transition: box-shadow .2s; }
        .review-card:hover { box-shadow: 0 6px 24px rgba(14,165,233,.12); }
        .author-avatar { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--sky-400), var(--sky-700)); color: #fff; font-weight: 700; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }

        /* Hero */
        .hero-banner { background: linear-gradient(135deg, var(--sky-50) 0%, var(--sky-100) 100%); border-radius: 20px; }

        /* Pagination */
        .page-link { border: 1.5px solid var(--sky-200); color: var(--sky-600); border-radius: 8px !important; margin: 0 2px; }
        .page-link:hover { background: var(--sky-50); border-color: var(--sky-400); }
        .page-item.active .page-link { background: var(--sky-500); border-color: var(--sky-500); }

        /* Section titles */
        .section-title { color: var(--sky-900); font-weight: 800; }

        footer { background: #fff; border-top: 1px solid var(--sky-100); }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg nav-shop">
    <div class="container py-2">
        <a class="navbar-brand" href="/products">
            <i class="bi bi-shop-window me-2"></i>Shop<span>Mall</span>
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain" style="filter:invert(1);">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav me-3 mb-2 mb-lg-0">
                <li class="nav-item"><a class="nav-link" href="/products">전체</a></li>
                <li class="nav-item"><a class="nav-link" href="/product/category/TV">TV</a></li>
                <li class="nav-item"><a class="nav-link" href="/product/category/COMPUTER">컴퓨터</a></li>
                <li class="nav-item"><a class="nav-link" href="/product/category/PHONE">휴대폰</a></li>
            </ul>
            <form class="d-flex nav-search me-auto" action="/products/search" method="get">
                <input class="form-control" type="search" name="keyword" placeholder="상품 검색...">
                <button class="btn" type="submit"><i class="bi bi-search"></i></button>
            </form>

            {{#currentUser}}
            <div class="d-flex align-items-center gap-2 ms-3">
                {{#isAdmin}}
                <span class="admin-pill"><i class="bi bi-shield-fill me-1"></i>ADMIN</span>
                <a href="/admin/users" class="text-decoration-none nav-btn-solid">
                    <i class="bi bi-grid-3x3-gap me-1"></i>ERP
                </a>
                {{/isAdmin}}
                {{^isAdmin}}
                <span class="user-pill"><i class="bi bi-person-circle"></i>{{email}}</span>
                <a href="/user/profile" class="text-decoration-none nav-btn-outline">내 정보</a>
                {{/isAdmin}}
                <a href="/logout" class="text-decoration-none nav-btn-outline">로그아웃</a>
            </div>
            {{/currentUser}}
            {{^currentUser}}
            <div class="d-flex gap-2 ms-3">
                <a href="/login" class="text-decoration-none nav-btn-outline">로그인</a>
                <a href="/signup" class="text-decoration-none nav-btn-solid">회원가입</a>
            </div>
            {{/currentUser}}
        </div>
    </div>
</nav>

{{#msg}}
<div class="container mt-3">
    <div class="alert border-0 rounded-3 d-flex align-items-center gap-2 py-2"
         style="background:var(--sky-50);color:var(--sky-700);border-left:4px solid var(--sky-500) !important;">
        <i class="bi bi-check-circle-fill"></i>{{msg}}
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" style="font-size:.75rem;"></button>
    </div>
</div>
{{/msg}}
