<!doctype html>
<html lang="ko">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <title>Online shop</title>
    <style>
        :root {
            --sky-50:  #f7f8ef;
            --sky-100: #ecefdc;
            --sky-200: #d7ddb4;
            --sky-400: #aab86a;
            --sky-500: #7f8f3a;
            --sky-600: #66742f;
            --sky-700: #4f5a25;
            --sky-900: #283014;
            --olive-50:  #f7f8ef;
            --olive-100: #ecefdc;
            --olive-200: #d7ddb4;
            --olive-400: #aab86a;
            --olive-500: #7f8f3a;
            --olive-600: #66742f;
            --olive-700: #4f5a25;
            --olive-900: #283014;
            --cream: #fbf8ef;
            --text-dark: #26301f;
            --text-muted: #6f7964;
            --radius-card: 8px;
        }

        * { box-sizing: border-box; }
        body {
            background: #fbfaf4;
            color: var(--text-dark);
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        .nav-shop {
            background: linear-gradient(135deg, var(--olive-900) 0%, var(--olive-700) 54%, var(--olive-500) 100%);
            box-shadow: 0 4px 22px rgba(40,48,20,.32);
            padding: 0;
        }
        .nav-shop .navbar-brand {
            font-size: 1.35rem;
            font-weight: 850;
            color: #fff !important;
            letter-spacing: 0;
        }
        .brand-icon {
            width: 34px;
            height: 34px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            background: rgba(255,255,255,.16);
            color: #eef2d4;
        }
        .nav-shop .navbar-brand span { color: #dfe8a8; }
        .nav-shop .nav-link {
            color: rgba(255,255,255,.82) !important;
            font-weight: 600;
            font-size: .9rem;
            padding: .58rem .88rem !important;
            border-radius: 8px;
            transition: all .2s;
        }
        .nav-shop .nav-link:hover,
        .nav-shop .nav-link.active-cat {
            color: #fff !important;
            background: rgba(255,255,255,.13);
        }

        .nav-search .form-control {
            min-width: 220px;
            border: 1px solid rgba(255,255,255,.12);
            border-right: none;
            border-radius: 8px 0 0 8px;
            background: rgba(255,255,255,.14);
            color: #fff;
            font-size: .875rem;
        }
        .nav-search .form-control::placeholder { color: rgba(255,255,255,.65); }
        .nav-search .form-control:focus {
            background: rgba(255,255,255,.22);
            box-shadow: none;
            color: #fff;
        }
        .nav-search .btn {
            border: none;
            border-radius: 0 8px 8px 0;
            background: rgba(255,255,255,.2);
            color: #fff;
        }
        .nav-search .btn:hover { background: rgba(255,255,255,.3); }

        .user-pill {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 4px 14px;
            border-radius: 999px;
            background: rgba(255,255,255,.16);
            color: rgba(255,255,255,.92);
            font-size: .8rem;
        }
        .admin-pill {
            padding: 4px 10px;
            border: 1px solid rgba(223,232,168,.45);
            border-radius: 999px;
            background: rgba(223,232,168,.18);
            color: #f4f7dc;
            font-size: .78rem;
            font-weight: 700;
        }
        .nav-btn-outline {
            padding: 5px 14px;
            border: 1.5px solid rgba(255,255,255,.48);
            border-radius: 8px;
            color: rgba(255,255,255,.92) !important;
            font-size: .82rem;
            text-decoration: none;
            transition: all .2s;
        }
        .nav-btn-outline:hover { background: rgba(255,255,255,.13); color: #fff !important; }
        .nav-btn-solid {
            padding: 5px 14px;
            border-radius: 8px;
            background: rgba(255,255,255,.92);
            color: var(--olive-700) !important;
            font-size: .82rem;
            font-weight: 750;
            text-decoration: none;
            transition: all .2s;
        }
        .nav-btn-solid:hover { background: #fff; }

        .shop-card {
            background: #fff;
            border: 1px solid var(--olive-100);
            border-radius: var(--radius-card);
            transition: transform .25s, box-shadow .25s, border-color .25s;
        }
        .shop-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 14px 42px rgba(79,90,37,.16);
            border-color: var(--olive-200);
        }
        .product-img-wrap {
            aspect-ratio: 1/1;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border-radius: var(--radius-card) var(--radius-card) 0 0;
            background: var(--olive-50);
        }
        .product-img-wrap img { width: 100%; height: 100%; object-fit: cover; }
        .product-img-placeholder { color: var(--olive-200); font-size: 3rem; }

        .cat-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 999px;
            background: var(--olive-100);
            color: var(--olive-700);
            font-size: .72rem;
            font-weight: 700;
        }
        .cat-badge-lg { padding: 5px 14px; font-size: .8rem; }
        .price-tag { color: var(--olive-700); font-weight: 850; }

        .btn-sky {
            border: none;
            border-radius: 8px;
            background: var(--olive-500);
            color: #fff;
            font-weight: 700;
            transition: all .2s;
        }
        .btn-sky:hover {
            background: var(--olive-600);
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 7px 20px rgba(102,116,47,.28);
        }
        .btn-sky-outline {
            border: 1.5px solid var(--olive-500);
            border-radius: 8px;
            color: var(--olive-600);
            background: transparent;
            font-weight: 700;
            transition: all .2s;
        }
        .btn-sky-outline:hover { background: var(--olive-50); }
        .input-sky:focus {
            border-color: var(--olive-400);
            box-shadow: 0 0 0 3px rgba(127,143,58,.15);
        }

        .review-card {
            padding: 20px 24px;
            border: 1px solid var(--olive-100);
            border-radius: 8px;
            background: #fff;
            transition: box-shadow .2s;
        }
        .review-card:hover { box-shadow: 0 6px 24px rgba(79,90,37,.12); }
        .author-avatar {
            width: 40px;
            height: 40px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--olive-400), var(--olive-700));
            color: #fff;
            font-weight: 800;
        }
        .hero-banner {
            border-radius: 8px;
            background: linear-gradient(135deg, var(--olive-50), var(--olive-100));
        }
        .page-link {
            margin: 0 2px;
            border: 1.5px solid var(--olive-200);
            border-radius: 8px !important;
            color: var(--olive-600);
        }
        .page-link:hover { background: var(--olive-50); border-color: var(--olive-400); }
        .page-item.active .page-link { background: var(--olive-500); border-color: var(--olive-500); }
        .section-title { color: var(--olive-900); font-weight: 850; }
        footer { background: #fff; border-top: 1px solid var(--olive-100); }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg nav-shop">
    <div class="container py-2">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/products">
            <span class="brand-icon"><i class="bi bi-basket2-fill"></i></span>
            Online <span>shop</span>
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain" style="filter:invert(1);">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav me-3 mb-2 mb-lg-0">
                <li class="nav-item"><a class="nav-link" href="/products">전체</a></li>
                <li class="nav-item"><a class="nav-link" href="/product/category/TV">TV</a></li>
                <li class="nav-item"><a class="nav-link" href="/product/category/COMPUTER">컴퓨터</a></li>
                <li class="nav-item"><a class="nav-link" href="/product/category/PHONE">휴대폰</a></li>
            </ul>
            <form class="d-flex nav-search me-auto" action="/products/search" method="get">
                <input class="form-control" type="search" name="keyword" placeholder="상품 검색">
                <button class="btn" type="submit"><i class="bi bi-search-heart"></i></button>
            </form>

            {{#currentUser}}
            <div class="d-flex align-items-center gap-2 ms-3">
                {{#isAdmin}}
                <span class="admin-pill"><i class="bi bi-shield-lock-fill me-1"></i>ADMIN</span>
                <a href="/admin/users" class="nav-btn-solid">
                    <i class="bi bi-kanban-fill me-1"></i>ERP
                </a>
                {{/isAdmin}}
                {{^isAdmin}}
                <span class="user-pill"><i class="bi bi-person-badge-fill"></i>{{email}}</span>
                <a href="/user/profile" class="nav-btn-outline">내 정보</a>
                {{/isAdmin}}
                <a href="/logout" class="nav-btn-outline">로그아웃</a>
            </div>
            {{/currentUser}}
            {{^currentUser}}
            <div class="d-flex gap-2 ms-3">
                <a href="/login" class="nav-btn-outline">로그인</a>
                <a href="/signup" class="nav-btn-solid">회원가입</a>
            </div>
            {{/currentUser}}
        </div>
    </div>
</nav>

{{#msg}}
<div class="container mt-3">
    <div class="alert border-0 rounded-3 d-flex align-items-center gap-2 py-2"
         style="background:var(--olive-50);color:var(--olive-700);border-left:4px solid var(--olive-500) !important;">
        <i class="bi bi-patch-check-fill"></i>{{msg}}
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" style="font-size:.75rem;"></button>
    </div>
</div>
{{/msg}}
