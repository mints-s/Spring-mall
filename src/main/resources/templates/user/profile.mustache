{{>header}}
<main class="container py-5" style="max-width:700px;">
    <h2 class="section-title mb-4"><i class="bi bi-person-badge-fill me-2"></i>내 정보</h2>

    <div class="card rounded-4 border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex align-items-center mb-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                     style="width:56px;height:56px;background:#e9ecd5;">
                    <i class="bi bi-person-hearts" style="font-size:1.8rem;color:#667134;"></i>
                </div>
                <div>
                    <div class="fw-bold fs-5" style="color:#59642f;">{{currentUser.email}}</div>
                    <small class="text-muted">가입일: {{currentUser.createdAtFormatted}}</small>
                </div>
            </div>
            <table class="table table-borderless mb-0">
                <tr>
                    <th class="text-muted" style="width:120px;">이메일</th>
                    <td>{{currentUser.email}}</td>
                </tr>
                <tr>
                    <th class="text-muted">계정 상태</th>
                    <td><span class="badge" style="background:#667134;">활성</span></td>
                </tr>
                <tr>
                    <th class="text-muted">가입일</th>
                    <td>{{currentUser.createdAtFormatted}}</td>
                </tr>
            </table>
        </div>
    </div>

    <div class="card rounded-4 border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <h5 class="mb-3"><i class="bi bi-clock-history me-2" style="color:#667134;"></i>최근 로그인 기록</h5>
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>로그인 일시</th>
                        <th>IP 주소</th>
                    </tr>
                </thead>
                <tbody>
                    {{#loginHistory}}
                    <tr>
                        <td>{{loginAtFormatted}}</td>
                        <td><span class="badge bg-light text-dark">{{ipAddress}}</span></td>
                    </tr>
                    {{/loginHistory}}
                    {{^loginHistory}}
                    <tr><td colspan="2" class="text-muted text-center">로그인 기록이 없습니다.</td></tr>
                    {{/loginHistory}}
                </tbody>
            </table>
        </div>
    </div>

    <div class="card rounded-4 border-danger shadow-sm">
        <div class="card-body p-4">
            <h5 class="text-danger mb-2"><i class="bi bi-exclamation-triangle me-1"></i>회원 탈퇴</h5>
            <p class="text-muted small mb-3">탈퇴 시 계정은 비활성화되며 복구할 수 없습니다.</p>
            <form action="/user/withdraw" method="post"
                  onsubmit="return confirm('정말로 탈퇴하시겠습니까?');">
                <button type="submit" class="btn btn-outline-danger">
                    <i class="bi bi-person-x me-1"></i>회원 탈퇴
                </button>
            </form>
        </div>
    </div>

    <div class="mt-3">
        <a href="/products" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>쇼핑 계속하기
        </a>
    </div>
</main>
{{>footer}}
