{{>header}}

<main class="container py-5" style="max-width:720px;">
    <div class="card rounded-4 border-0 shadow-sm">
        <div class="card-body p-5">
            <h2 class="fw-bold mb-4 section-title"><i class="bi bi-pencil-square me-2"></i>게시글 수정</h2>
            <form action="/articles/update" method="post">
                <input type="hidden" name="id" value="{{article.id}}">
                <div class="mb-3">
                    <label class="form-label fw-semibold">제목</label>
                    <input type="text" class="form-control search-input" name="title" value="{{article.title}}" required>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-semibold">내용</label>
                    <textarea rows="5" class="form-control search-input" name="content" required>{{article.content}}</textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-sky px-4">
                        <i class="bi bi-check2-circle me-1"></i>저장
                    </button>
                    <a href="/articles/{{article.id}}" class="btn btn-outline-secondary px-4">돌아가기</a>
                </div>
            </form>
        </div>
    </div>
</main>

{{>footer}}
