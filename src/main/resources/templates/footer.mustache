<footer class="mt-5 pt-5 pb-4">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="fw-bold fs-5 mb-2" style="color:var(--olive-700);">
                    <i class="bi bi-basket2-fill me-2"></i>Online shop
                </div>
                <p class="text-muted small mb-3">필요한 상품을 차분하고 편하게 둘러볼 수 있는 쇼핑 공간입니다.</p>
                <div class="d-flex gap-2">
                    <a href="#" class="footer-social"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="footer-social"><i class="bi bi-chat-dots-fill"></i></a>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <h6 class="fw-bold mb-3" style="color:var(--olive-700);">카테고리</h6>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2"><a href="/products" class="text-muted text-decoration-none small footer-link">전체 상품</a></li>
                    <li class="mb-2"><a href="/product/category/TV" class="text-muted text-decoration-none small footer-link">TV</a></li>
                    <li class="mb-2"><a href="/product/category/COMPUTER" class="text-muted text-decoration-none small footer-link">컴퓨터</a></li>
                    <li><a href="/product/category/PHONE" class="text-muted text-decoration-none small footer-link">휴대폰</a></li>
                </ul>
            </div>

            <div class="col-lg-3 col-md-6">
                <h6 class="fw-bold mb-3" style="color:var(--olive-700);">서비스</h6>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2"><a href="/product/new" class="text-muted text-decoration-none small footer-link">상품 등록</a></li>
                    <li class="mb-2"><a href="/products/search" class="text-muted text-decoration-none small footer-link">상품 검색</a></li>
                </ul>
            </div>

            <div class="col-lg-3 col-md-6">
                <h6 class="fw-bold mb-3" style="color:var(--olive-700);">내 계정</h6>

                {{#currentUser}}
                <div class="p-3 rounded-3 mb-3" style="background:var(--olive-50);border:1px solid var(--olive-100);">
                    {{#isAdmin}}
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:36px;height:36px;background:linear-gradient(135deg,#a16207,#854d0e);flex-shrink:0;">
                            <i class="bi bi-shield-lock-fill text-white" style="font-size:.9rem;"></i>
                        </div>
                        <div>
                            <div class="fw-semibold" style="font-size:.82rem;color:var(--olive-900);">{{email}}</div>
                            <div style="font-size:.7rem;color:#854d0e;font-weight:700;">관리자 계정</div>
                        </div>
                    </div>
                    <a href="/admin/users" class="btn btn-sm w-100 mb-1 fw-semibold"
                       style="background:linear-gradient(135deg,#a16207,#854d0e);color:#fff;border:none;border-radius:8px;font-size:.8rem;">
                        <i class="bi bi-kanban-fill me-1"></i>ERP 관리자 페이지
                    </a>
                    {{/isAdmin}}
                    {{^isAdmin}}
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:36px;height:36px;background:linear-gradient(135deg,var(--olive-500),var(--olive-700));flex-shrink:0;">
                            <i class="bi bi-person-badge-fill text-white" style="font-size:.9rem;"></i>
                        </div>
                        <div>
                            <div class="fw-semibold" style="font-size:.82rem;color:var(--olive-900);">{{email}}</div>
                            <div style="font-size:.7rem;color:var(--olive-600);">일반 회원</div>
                        </div>
                    </div>
                    <a href="/user/profile" class="btn btn-sm w-100 mb-1"
                       style="background:var(--olive-50);color:var(--olive-700);border:1.5px solid var(--olive-200);border-radius:8px;font-size:.8rem;">
                        <i class="bi bi-person-lines-fill me-1"></i>내 정보 보기
                    </a>
                    {{/isAdmin}}
                    <a href="/logout" class="btn btn-sm w-100"
                       style="background:#fff;color:#64748b;border:1.5px solid #e2e8f0;border-radius:8px;font-size:.8rem;">
                        <i class="bi bi-door-closed-fill me-1"></i>로그아웃
                    </a>
                </div>
                {{/currentUser}}

                {{^currentUser}}
                <div class="p-3 rounded-3" style="background:var(--olive-50);border:1px solid var(--olive-100);">
                    <p class="text-muted small mb-3">로그인하여 더 많은 서비스를 이용하세요</p>
                    <a href="/login" class="btn btn-sm w-100 mb-2 fw-semibold"
                       style="background:linear-gradient(135deg,var(--olive-700),var(--olive-500));color:#fff;border:none;border-radius:8px;font-size:.82rem;">
                        <i class="bi bi-door-open-fill me-1"></i>로그인
                    </a>
                    <a href="/signup" class="btn btn-sm w-100"
                       style="background:#fff;color:var(--olive-600);border:1.5px solid var(--olive-200);border-radius:8px;font-size:.82rem;font-weight:700;">
                        <i class="bi bi-bag-check-fill me-1"></i>회원가입
                    </a>
                </div>
                {{/currentUser}}
            </div>
        </div>

        <hr style="border-color:var(--olive-100);margin-top:2rem;">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <small class="text-muted">&copy; 2026 Online shop. All rights reserved.</small>
            <small class="text-muted">편안하고 믿을 수 있는 쇼핑 경험을 제공합니다.</small>
        </div>
    </div>
</footer>

<style>
.footer-link:hover { color: var(--olive-600) !important; }
.footer-social {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--olive-100);
    color: var(--olive-600);
}
.footer-social:hover { background: var(--olive-200); color: var(--olive-700); }
</style>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
