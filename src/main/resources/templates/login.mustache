<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>로그인 · ShopMall</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root { --sky-500:#0ea5e9; --sky-600:#0284c7; --sky-700:#0369a1; --sky-900:#0c4a6e; }
        body {
            background: linear-gradient(135deg, var(--sky-900) 0%, var(--sky-700) 40%, var(--sky-500) 100%);
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
        }
        .login-card {
            background: rgba(255,255,255,.97);
            border-radius: 24px;
            box-shadow: 0 32px 80px rgba(12,74,110,.35);
            width: 100%; max-width: 420px;
            padding: 48px 40px;
        }
        .form-control { border-radius: 12px; border: 1.5px solid #e2e8f0; padding: .75rem 1rem; }
        .form-control:focus { border-color: var(--sky-400, #38bdf8); box-shadow: 0 0 0 3px rgba(14,165,233,.15); }
        .btn-login {
            background: linear-gradient(135deg, var(--sky-700) 0%, var(--sky-500) 100%);
            border: none; border-radius: 12px; color: #fff; font-weight: 700;
            padding: .8rem; font-size: 1rem; transition: all .2s;
        }
        .btn-login:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(14,165,233,.4); color: #fff; }
        .divider { display: flex; align-items: center; gap: 12px; color: #94a3b8; font-size: .85rem; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: #e2e8f0; }
    </style>
</head>
<body>
<div class="login-card">
    <div class="text-center mb-4">
        <div class="mb-3" style="width:56px;height:56px;background:linear-gradient(135deg,var(--sky-700),var(--sky-500));border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto;">
            <i class="bi bi-shop-window text-white fs-4"></i>
        </div>
        <h2 class="fw-bold mb-1" style="color:var(--sky-900);">로그인</h2>
        <p class="text-muted small">ShopMall에 오신 것을 환영합니다</p>
    </div>

    {{#loginError}}
    <div class="alert border-0 rounded-3 py-2 mb-3" style="background:#fef2f2;color:#dc2626;font-size:.85rem;">
        <i class="bi bi-exclamation-circle me-1"></i>{{loginError}}
    </div>
    {{/loginError}}
    {{#withdrawnMsg}}
    <div class="alert border-0 rounded-3 py-2 mb-3" style="background:#f0fdf4;color:#16a34a;font-size:.85rem;">
        <i class="bi bi-check-circle me-1"></i>{{withdrawnMsg}}
    </div>
    {{/withdrawnMsg}}
    {{#signupSuccess}}
    <div class="alert border-0 rounded-3 py-2 mb-3" style="background:#f0fdf4;color:#16a34a;font-size:.85rem;">
        <i class="bi bi-check-circle me-1"></i>{{signupSuccess}}
    </div>
    {{/signupSuccess}}

    <form action="/login" method="POST">
        {{#_csrf}}<input type="hidden" name="{{parameterName}}" value="{{token}}"/>{{/_csrf}}
        <div class="mb-3">
            <label class="form-label fw-semibold small text-muted">이메일</label>
            <input type="email" class="form-control" name="username" placeholder="email@example.com" required autofocus>
        </div>
        <div class="mb-4">
            <label class="form-label fw-semibold small text-muted">비밀번호</label>
            <input type="password" class="form-control" name="password" placeholder="비밀번호" required>
        </div>
        <button type="submit" class="btn btn-login w-100">
            <i class="bi bi-box-arrow-in-right me-2"></i>로그인
        </button>
    </form>

    <div class="divider my-4">또는</div>
    <div class="text-center">
        <span class="text-muted small">계정이 없으신가요?</span>
        <a href="/signup" class="fw-semibold text-decoration-none ms-2" style="color:var(--sky-600);">회원가입</a>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
