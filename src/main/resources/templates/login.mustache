<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>로그인 · Online shop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --olive-50:#f7f8ef;
            --olive-100:#ecefdc;
            --olive-300:#c5cf91;
            --olive-500:#7f8f3a;
            --olive-600:#66742f;
            --olive-700:#4f5a25;
            --olive-900:#283014;
            --cream:#fbf8ef;
            --ink:#26301f;
            --muted:#76806a;
        }
        * { box-sizing: border-box; }
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 24px;
            color: var(--ink);
            background:
                radial-gradient(circle at 12% 18%, rgba(197,207,145,.36), transparent 28%),
                linear-gradient(135deg, var(--olive-900) 0%, var(--olive-700) 46%, #8e9c4a 100%);
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
        .login-card {
            width: 100%;
            max-width: 420px;
            padding: 44px 38px;
            border: 1px solid rgba(255,255,255,.66);
            border-radius: 8px;
            background: rgba(251,248,239,.97);
            box-shadow: 0 28px 70px rgba(25,32,14,.32);
        }
        .brand-mark {
            width: 58px;
            height: 58px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 18px;
            border-radius: 8px;
            color: #fff;
            background: linear-gradient(135deg, var(--olive-700), var(--olive-500));
            box-shadow: 0 10px 24px rgba(79,90,37,.28);
        }
        .brand-name {
            color: var(--olive-900);
            font-size: 1.4rem;
            font-weight: 800;
            margin-bottom: 2px;
        }
        .brand-copy { color: var(--muted); font-size: .9rem; }
        .form-label { color: #68725a; }
        .form-control {
            border-radius: 8px;
            border: 1.5px solid #dfe4c8;
            padding: .78rem 1rem;
            background: #fffdf7;
        }
        .form-control:focus {
            border-color: var(--olive-500);
            box-shadow: 0 0 0 3px rgba(127,143,58,.16);
        }
        .btn-login {
            padding: .82rem;
            border: none;
            border-radius: 8px;
            color: #fff;
            font-weight: 800;
            background: linear-gradient(135deg, var(--olive-700), var(--olive-500));
            transition: transform .2s, box-shadow .2s;
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 24px rgba(102,116,47,.34);
            color: #fff;
        }
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #8b947f;
            font-size: .85rem;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #dfe4c8;
        }
        .link-olive { color: var(--olive-600); }
        .link-olive:hover { color: var(--olive-700); }
    </style>
</head>
<body>
<div class="login-card">
    <div class="text-center mb-4">
        <div class="brand-mark">
            <i class="bi bi-basket2-fill fs-3"></i>
        </div>
        <div class="brand-name">Online shop</div>
        <p class="brand-copy mb-0">계정으로 로그인하고 쇼핑을 이어가세요</p>
    </div>

    {{#loginError}}
    <div class="alert border-0 rounded-3 py-2 mb-3" style="background:#fef2f2;color:#b91c1c;font-size:.85rem;">
        <i class="bi bi-x-circle me-1"></i>{{loginError}}
    </div>
    {{/loginError}}
    {{#withdrawnMsg}}
    <div class="alert border-0 rounded-3 py-2 mb-3" style="background:#f7f8ef;color:#4f5a25;font-size:.85rem;">
        <i class="bi bi-patch-check-fill me-1"></i>{{withdrawnMsg}}
    </div>
    {{/withdrawnMsg}}
    {{#signupSuccess}}
    <div class="alert border-0 rounded-3 py-2 mb-3" style="background:#f7f8ef;color:#4f5a25;font-size:.85rem;">
        <i class="bi bi-patch-check-fill me-1"></i>{{signupSuccess}}
    </div>
    {{/signupSuccess}}

    <form action="/login" method="POST">
        {{#_csrf}}<input type="hidden" name="{{parameterName}}" value="{{token}}"/>{{/_csrf}}
        <div class="mb-3">
            <label class="form-label fw-semibold small">이메일</label>
            <input type="email" class="form-control" name="username" placeholder="email@example.com" required autofocus>
        </div>
        <div class="mb-4">
            <label class="form-label fw-semibold small">비밀번호</label>
            <input type="password" class="form-control" name="password" placeholder="비밀번호" required>
        </div>
        <button type="submit" class="btn btn-login w-100">
            <i class="bi bi-door-open-fill me-2"></i>로그인
        </button>
    </form>

    <div class="divider my-4">또는</div>
    <div class="text-center">
        <span class="text-muted small">아직 계정이 없나요?</span>
        <a href="/signup" class="fw-semibold text-decoration-none ms-2 link-olive">회원가입</a>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
