{{>header}}
<main class="container py-5" style="max-width:640px;">
    <div class="card rounded-4 border-0 shadow-sm">
        <div class="card-body p-5">
            <h2 class="fw-bold mb-4 section-title"><i class="bi bi-plus-circle me-2"></i>상품 등록</h2>
            <form action="/product/create" method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label fw-semibold">상품명</label>
                    <input type="text" class="form-control search-input" name="name" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">가격 (원)</label>
                    <input type="number" class="form-control search-input" name="price" min="0" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">카테고리</label>
                    <select class="form-select search-input" name="category" required>
                        <option value="">카테고리 선택</option>
                        {{#categories}}
                        <option value="{{codeKey}}">{{codeName}}</option>
                        {{/categories}}
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">상품 설명</label>
                    <textarea class="form-control search-input" name="description" rows="3"></textarea>
                </div>

                <!-- 이미지 업로드 -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        상품 이미지
                        <small class="text-muted fw-normal ms-1">첫 번째 이미지가 대표 이미지로 설정됩니다</small>
                    </label>
                    <div class="upload-area rounded-3 border-2 border-dashed p-4 text-center"
                         style="border: 2px dashed #bae6fd; cursor:pointer; background:#f8faff;"
                         onclick="document.getElementById('imageInput').click()">
                        <i class="bi bi-cloud-arrow-up" style="font-size:2rem; color:#0ea5e9;"></i>
                        <p class="mb-0 mt-2 text-muted small">클릭하여 이미지 선택 또는 드래그 앤 드롭</p>
                        <p class="text-muted" style="font-size:0.75rem;">JPG, PNG, WebP, GIF · 최대 10MB · 여러 장 가능</p>
                    </div>
                    <input type="file" id="imageInput" name="images" multiple
                           accept="image/jpeg,image/png,image/webp,image/gif"
                           class="d-none" onchange="previewImages(this)">
                    <div id="imagePreview" class="d-flex gap-2 flex-wrap mt-3"></div>
                </div>

                {{#imageError}}
                <div class="alert alert-warning small py-2">{{imageError}}</div>
                {{/imageError}}

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-lg me-1"></i>등록하기
                    </button>
                    <a href="/products" class="btn btn-outline-secondary px-4">취소</a>
                </div>
            </form>
        </div>
    </div>
</main>

<script>
function previewImages(input) {
    const preview = document.getElementById('imagePreview');
    preview.innerHTML = '';
    [...input.files].forEach((file, i) => {
        const reader = new FileReader();
        reader.onload = e => {
            const wrapper = document.createElement('div');
            wrapper.className = 'position-relative';
            wrapper.innerHTML = `
                <img src="${e.target.result}" class="rounded-2 object-fit-cover"
                     style="width:80px;height:80px;border:2px solid ${i===0?'#0ea5e9':'#e2e8f0'};">
                ${i===0 ? '<span class="position-absolute top-0 start-0 badge bg-primary" style="font-size:0.6rem;">대표</span>' : ''}
            `;
            preview.appendChild(wrapper);
        };
        reader.readAsDataURL(file);
    });
}
</script>
{{>footer}}
