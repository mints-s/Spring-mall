{{>admin-header}}

<div class="erp-page-title"><i class="bi bi-person-lines-fill" style="color:#667134;"></i> 유저 관리</div>

<div class="erp-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>유저 목록</span>
        <span class="text-muted" style="font-size:0.8rem;">총 {{pageInfo.totalElements}}명</span>
    </div>
    <table class="erp-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>이메일</th>
                <th>권한</th>
                <th>상태</th>
                <th>가입일</th>
                <th>관리</th>
            </tr>
        </thead>
        <tbody>
            {{#users}}
            <tr>
                <td class="text-muted">{{id}}</td>
                <td><i class="bi bi-person-badge-fill me-1" style="color:#667134;"></i>{{email}}</td>
                <td>
                    {{#admin}}<span class="erp-badge badge-admin"><i class="bi bi-shield-lock-fill me-1"></i>ADMIN</span>{{/admin}}
                    {{^admin}}<span class="erp-badge badge-user">USER</span>{{/admin}}
                </td>
                <td>
                    {{#enabled}}<span class="erp-badge badge-active">활성</span>{{/enabled}}
                    {{^enabled}}<span class="erp-badge badge-inactive">비활성</span>{{/enabled}}
                </td>
                <td class="text-muted">{{createdAtFormatted}}</td>
                <td>
                    <div class="d-flex gap-1 flex-wrap">
                        {{#admin}}
                        <form action="/admin/users/{{id}}/role" method="post" class="d-inline">
                            <input type="hidden" name="role" value="USER">
                            <button class="erp-btn" style="color:#6b7250;border-color:#cdd3aa;">USER로 변경</button>
                        </form>
                        {{/admin}}
                        {{^admin}}
                        <form action="/admin/users/{{id}}/role" method="post" class="d-inline">
                            <input type="hidden" name="role" value="ADMIN">
                            <button class="erp-btn" style="color:#8a5a16;border-color:#d8c086;">ADMIN으로 변경</button>
                        </form>
                        {{/admin}}
                        {{#enabled}}
                        <form action="/admin/users/{{id}}/deactivate" method="post" class="d-inline"
                              onsubmit="return confirm('이 계정을 비활성화하시겠습니까?');">
                            <button class="erp-btn" style="color:#a23b34;border-color:#e3a59d;">비활성화</button>
                        </form>
                        {{/enabled}}
                        {{^enabled}}
                        <form action="/admin/users/{{id}}/activate" method="post" class="d-inline">
                            <button class="erp-btn" style="color:#315f2e;border-color:#9fbd8d;">활성화</button>
                        </form>
                        {{/enabled}}
                    </div>
                </td>
            </tr>
            {{/users}}
        </tbody>
    </table>
    {{>admin/pagination}}
</div>

{{>admin-footer}}
