{{>admin-header}}

<div class="erp-page-title"><i class="bi bi-chat-left-text-fill" style="color:#0ea5e9;"></i> 댓글 관리</div>

<div class="erp-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>댓글 목록</span>
        <span class="text-muted" style="font-size:0.8rem;">총 {{pageInfo.totalElements}}개</span>
    </div>
    <table class="erp-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>게시글 ID</th>
                <th>작성자</th>
                <th>내용</th>
                <th>등록일</th>
                <th>관리</th>
            </tr>
        </thead>
        <tbody>
            {{#comments}}
            <tr>
                <td class="text-muted">{{id}}</td>
                <td>
                    <a href="/articles/{{article.id}}" target="_blank" class="text-primary text-decoration-none">
                        #{{article.id}}
                    </a>
                </td>
                <td><span class="erp-badge badge-user">{{nickname}}</span></td>
                <td>{{body}}</td>
                <td class="text-muted">{{createdAtFormatted}}</td>
                <td>
                    <form action="/admin/comments/{{id}}/delete" method="post" class="d-inline"
                          onsubmit="return confirm('댓글을 삭제하시겠습니까?');">
                        <button class="erp-btn" style="color:#dc2626;border-color:#fca5a5;">
                            <i class="bi bi-trash"></i> 삭제
                        </button>
                    </form>
                </td>
            </tr>
            {{/comments}}
        </tbody>
    </table>
    {{>admin/pagination}}
</div>

{{>admin-footer}}
