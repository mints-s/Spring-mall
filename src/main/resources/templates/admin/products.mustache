{{>admin-header}}

<div class="erp-page-title"><i class="bi bi-box-seam-fill" style="color:#0ea5e9;"></i> 상품 관리</div>

<div class="erp-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>상품 목록</span>
        <div class="d-flex gap-2 align-items-center">
            <span class="text-muted" style="font-size:0.8rem;">총 {{pageInfo.totalElements}}개</span>
            <a href="/product/new" class="erp-btn" style="color:#0369a1;border-color:#7dd3fc;text-decoration:none;">
                <i class="bi bi-plus me-1"></i>상품 등록
            </a>
        </div>
    </div>
    <table class="erp-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>상품명</th>
                <th>카테고리</th>
                <th>가격</th>
                <th>설명</th>
                <th>등록일</th>
                <th>관리</th>
            </tr>
        </thead>
        <tbody>
            {{#products}}
            <tr>
                <td class="text-muted">{{id}}</td>
                <td><strong>{{name}}</strong></td>
                <td><span class="erp-badge badge-user">{{category}}</span></td>
                <td>₩{{price}}</td>
                <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="{{description}}">{{description}}</td>
                <td class="text-muted">{{createdAtFormatted}}</td>
                <td>
                    <div class="d-flex gap-1">
                        <a href="/admin/products/{{id}}/edit" class="erp-btn" style="color:#0369a1;border-color:#7dd3fc;text-decoration:none;">
                            <i class="bi bi-pencil"></i> 수정
                        </a>
                        <form action="/admin/products/{{id}}/delete" method="post" class="d-inline"
                              onsubmit="return confirm('삭제 하시겠습니까?');">
                            <button class="erp-btn" style="color:#dc2626;border-color:#fca5a5;">
                                <i class="bi bi-trash"></i> 삭제
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
            {{/products}}
        </tbody>
    </table>
    {{>admin/pagination}}
</div>

{{>admin-footer}}
