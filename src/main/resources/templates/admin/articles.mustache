{{>admin-header}}

<div class="erp-page-title"><i class="bi bi-file-text-fill" style="color:#0ea5e9;"></i> 게시글 관리</div>

<div class="erp-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>게시글 목록</span>
        <span class="text-muted" style="font-size:0.8rem;">총 {{pageInfo.totalElements}}개</span>
    </div>
    <table class="erp-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>제목</th>
                <th>내용</th>
                <th>등록일</th>
                <th>수정일</th>
                <th>관리</th>
            </tr>
        </thead>
        <tbody>
            {{#articles}}
            <tr>
                <td class="text-muted">{{id}}</td>
                <td><strong>{{title}}</strong></td>
                <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="{{content}}">{{content}}</td>
                <td class="text-muted">{{createdAtFormatted}}</td>
                <td class="text-muted">{{updatedAtFormatted}}</td>
                <td>
                    <form action="/admin/articles/{{id}}/delete" method="post" class="d-inline"
                          onsubmit="return confirm('게시글과 모든 댓글을 삭제합니다. 계속하시겠습니까?');">
                        <button class="erp-btn" style="color:#dc2626;border-color:#fca5a5;">
                            <i class="bi bi-trash"></i> 삭제
                        </button>
                    </form>
                </td>
            </tr>
            {{/articles}}
        </tbody>
    </table>
    {{>admin/pagination}}
</div>

{{>admin-footer}}
